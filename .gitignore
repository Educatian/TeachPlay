# Per-learner issued credentials contain hashed PII — keep out of public repo.
# The example assertion (assertion-example-v3.json) is fine to ship; real
# cohort issuances land in credential/assertions/ and are gitignored.
credential/assertions/
test-results/
playwright-report/
.smoke-server.log

# Python bytecode
__pycache__/
*.pyc
